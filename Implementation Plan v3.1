## 4. Phase 3: Unified Security & Gateway Logic (FastAPI & FastMCP)

#### [NEW] src/fhir_mcp/api/rest_routes.py
Enforce an `X-API-KEY` header to protect the DeepSense API Key. This secures our endpoints for an **Ambient EHR Sidecar UI** running in the clinician's browser.

```python
from fastapi import APIRouter, Depends, Query, HTTPException, Security
from fastapi.security.api_key import APIKeyHeader
from typing import List
import os
from fhir_mcp.models.intelligence_models import SemanticSuggestion

# Security Implementation
API_KEY_NAME = "X-API-KEY"
api_key_header = APIKeyHeader(name=API_KEY_NAME, auto_error=True)

async def verify_api_key(api_key_header: str = Security(api_key_header)):
    expected_key = os.getenv("INTERNAL_API_KEY")
    if not expected_key or api_key_header != expected_key:
        raise HTTPException(status_code=403, detail="Forbidden")
    return api_key_header

router = APIRouter(prefix="/api/v3", tags=["Clinical Intelligence"])

@router.get("/health_check")
async def combined_health_check():
    return {"status": "healthy", "protocols": ["rest", "mcp_internal"]}

@router.get("/semantic-search", response_model=List[SemanticSuggestion])
async def rest_semantic_search(
    q: str = Query(...), 
    api_key: str = Depends(verify_api_key),
    intelligence=Depends(get_intelligence_layer)
):
    results = await intelligence.get_semantic_suggestions(q)
    return results
```

#### [MODIFY] src/fhir_mcp/server.py
Apply `CORSMiddleware` and the `ProtocolTaggingMiddleware` to the FastMCP `server._app`.

```python
from fastmcp import FastMCP
from fastapi.middleware.cors import CORSMiddleware
from fhir_mcp.api.rest_routes import router as rest_router
from fhir_mcp.middleware.observability import ProtocolTaggingMiddleware
# ... other imports ...

def create_server() -> FastMCP:
    server = FastMCP(name="fhir-mcp-server")
    intelligence = ClinicalIntelligenceService(api_key=settings.deepsense_api_key)
    
    register_fhir_tools(server, fhir, intelligence)
    
    # --- UNIFIED GATEWAY LOGIC ---
    if hasattr(server, '_app'):
        # 1. Apply CORS for Ambient EHR Sidecar (e.g., React on localhost:3000)
        server._app.add_middleware(
            CORSMiddleware,
            allow_origins=["*"], # Tighten in production
            allow_credentials=True,
            allow_methods=["*"],
            allow_headers=["*"],
        )
        
        # 2. Add Protocol-Aware Telemetry
        server._app.add_middleware(ProtocolTaggingMiddleware)
        
        # 3. Mount REST endpoints
        server._app.include_router(rest_router)
        
    return server
```

