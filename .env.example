# FHIR Server Settings
FHIR_SERVER_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_SERVER_DISABLE_AUTHORIZATION=true

# Auth (optional - for Epic/Cerner/Private servers)
# FHIR_SERVER_AUTH_MODE=client_credentials # or authorization_code
# FHIR_SERVER_CLIENT_ID=your-client-id
# FHIR_SERVER_CLIENT_SECRET=your-client-secret
# FHIR_SERVER_TOKEN_URL=https://auth.example.com/token
# FHIR_SERVER_AUTHORIZE_URL=https://auth.example.com/authorize
# FHIR_SERVER_SCOPES=openid fhirUser user/Patient.read user/Condition.read
# FHIR_SERVER_ACCESS_TOKEN=your-pre-exchanged-token-for-headless-use

# MCP Server Settings
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
MCP_TRANSPORT=stdio # or sse

# Terminology (optional)
# NLM_API_KEY=your-nlm-api-key
# LOINC_USERNAME=your-loinc-username
# LOINC_PASSWORD=your-loinc-password

# Logging
LOG_LEVEL=INFO

# DeepSense Intelligence V2
DEEPSENSE_API_KEY=your-deepsense-api-key-here

# Gateway Security (V3.1)
INTERNAL_API_KEY=your-internal-api-key-for-rest-endpoints
ALLOWED_EHR_ORIGINS=http://localhost:3000,https://ehr.hospital.com
